{
  "expo": {
    "name": "Eventology",
    "slug": "eventology-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "eventology",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eventology.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Eventology needs camera access to scan ticket QR codes at the door."
      }
    },
    "android": {
      "package": "com.eventology.mobile",
      "permissions": [
        "NOTIFICATIONS",
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Eventology needs camera access to scan ticket QR codes at the door."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#065F46"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "paymentsEnabled": false,
      "router": {},
      "eas": {
        "projectId": "03061523-b7cc-49af-90ec-275fc50b5412"
      }
    },
    "owner": "kidus-abdula"
  }
}
