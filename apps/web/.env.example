# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase JWT Secret (for RLS bridge)
# Get this from: Supabase Dashboard → Settings → API → JWT Keys → Legacy JWT Secret
# This is the HS256 secret used to sign tokens that PostgREST validates.
# auth.uid() in RLS policies resolves to the 'sub' claim in this JWT.
# NOTE: if the project has migrated to asymmetric (ECC) signing keys, the
# legacy secret must remain a valid verification key or the authed path breaks.
SUPABASE_JWT_SECRET=<legacy-jwt-secret>

# Ticket HMAC Secret (for QR code signing)
# Generate with: openssl rand -base64 32
# This signs QR payloads to prevent forgery. Server-side verification
# uses constant-time comparison to prevent timing attacks.
# MUST match the secret used to sign existing (seeded) tickets.
TICKET_HMAC_SECRET=<hmac-secret>

# Payment Provider (stub for dev/MVP, chapa for production)
PAYMENT_PROVIDER=stub

# better-auth
BETTER_AUTH_SECRET=<random-secret>
BETTER_AUTH_URL=http://localhost:3000

# Chapa (deferred)
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=

# Resend (deferred)
RESEND_API_KEY=

# Africa's Talking (deferred)
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=Eventology

# OpenRouter (AI)
# Default provider is 'stub' (zero keys needed; deterministic fixtures).
# Set AI_PROVIDER=openrouter once you supply the key + real model IDs.
OPENROUTER_API_KEY=
AI_PROVIDER=stub
# Optional: override the 8-model chain (comma-separated). Defaults live in
# packages/config/src/ai.config.ts as the documented 8-model placeholders.
# AI_MODEL_CHAIN=model-a,model-b,model-c,model-d,model-e,model-f,model-g,model-h
# Optional: override tier boundaries (indices into AI_MODEL_CHAIN)
# AI_TIER_HEAVY_START=0
# AI_TIER_MEDIUM_START=2
# AI_TIER_LIGHT_START=5

# Expo Push
EXPO_ACCESS_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Feature flags
# ----------------------------------------------------------------------------

# Payments toggle (R3, MVP-default OFF).
# When `false`: the registration page disables paid tiers, the revenue /
# payout / commission UIs are hidden, the Chapa webview is unreachable.
# Free registration still works end-to-end (status=confirmed, ticket
# issued immediately). All payment code + provider seams + webhook
# handlers remain live; flipping this to `true` restores the full paid
# flow with zero code changes.
# Set to the literal `true` to opt in.
NEXT_PUBLIC_PAYMENTS_ENABLED=false
