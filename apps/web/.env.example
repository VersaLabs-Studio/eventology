# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase JWT Secret (for RLS bridge)
# Get this from: Supabase Dashboard → Settings → API → JWT Secret
# This is the HS256 secret used to sign tokens that PostgREST validates.
# auth.uid() in RLS policies resolves to the 'sub' claim in this JWT.
SUPABASE_JWT_SECRET=e0NbSRpnETydHMxMVXsHx/wk4wbjEJ1psGFBJJBSQu84Fw0MOz+4oaEfWXeyfdnJb+wFaWGqfokz3ZOwsiNWoA==

# Ticket HMAC Secret (for QR code signing)
# Generate with: openssl rand -base64 32
# This signs QR payloads to prevent forgery. Server-side verification
# uses constant-time comparison to prevent timing attacks.
TICKET_HMAC_SECRET=ShsZIcIfK0FPvg4tag7PSuAQ1PD5IVN6vh7Il8OmBmU=

# Payment Provider (stub for dev, chapa for production)
PAYMENT_PROVIDER=stub

# better-auth
BETTER_AUTH_SECRET=<random-secret>
BETTER_AUTH_URL=http://localhost:3000

# Chapa (deferred)
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=

# Resend (deferred)
RESEND_API_KEY=

# Africa's Talking (deferred)
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=Eventology

# OpenRouter (AI)
OPENROUTER_API_KEY=<openrouter-key>

# Expo Push
EXPO_ACCESS_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
